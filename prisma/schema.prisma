generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id                   String                @id @default(cuid())
  nome                 String                @unique
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  acertos              AcertoContas[]
  atividades           AtividadeLog[]
  bancos               Banco[]
  categorias           Categoria[]
  fechamentosAnuais    FechamentoAnual[]
  integrantesGrupo     IntegranteGrupo[]
  investimentos        Investimento[]
  lancamentos          Lancamento[]
  orcamentos           OrcamentoPlanejado[]
  pessoas              Pessoa[]
  posicoesInvestimento PosicaoInvestimento[]
  posicoesPatrimonio   PosicaoPatrimonio[]
  preferencia          Preferencia?
  receitas             Receita[]
  users                User[]
}

model Preferencia {
  id          String    @id @default(cuid())
  householdId String    @unique
  moeda       String    @default("BRL")
  idioma      String    @default("pt-BR")
  tema        String    @default("CLARO")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id])
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  nome         String
  householdId  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  passwordHash String
  lastDevice   String?
  lastLoginAt  DateTime?
  lastSeenAt   DateTime?
  role         PapelUsuario   @default(EDITOR)
  atividades   AtividadeLog[]
  household    Household      @relation(fields: [householdId], references: [id])
}

model AtividadeLog {
  id          String    @id @default(cuid())
  acao        String
  dispositivo String?
  householdId String
  userId      String?
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@index([householdId, createdAt])
}

model Pessoa {
  id                          String               @id @default(cuid())
  nome                        String
  tipo                        TipoPessoa
  householdId                 String
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  acertosDevidos              AcertoContas[]       @relation("AcertoDe")
  acertosRecebidos            AcertoContas[]       @relation("AcertoPara")
  investimentos               Investimento[]
  lancamentosDivisao          Lancamento[]         @relation("LancamentoDivisao")
  lancamentosPagou            Lancamento[]         @relation("LancamentoPagou")
  orcamentos                  OrcamentoPlanejado[] @relation("OrcamentoDono")
  orcamentosDivisao           OrcamentoPlanejado[] @relation("OrcamentoDivisao")
  household                   Household            @relation(fields: [householdId], references: [id])
  posicoesPatrimonio          PosicaoPatrimonio[]
  receitas                    Receita[]
  integrantesDoGrupo          IntegranteGrupo[]    @relation("IntegranteGrupo_grupoIdToPessoa")
  participacoesComoIntegrante IntegranteGrupo[]    @relation("IntegranteGrupo_pessoaIdToPessoa")

  @@unique([householdId, nome])
}

// Composição de um grupo (Pessoa tipo CASAL/FAMILIA/OUTRO): quais pessoas
// INDIVIDUAL o formam e o peso relativo de cada uma na divisão dos gastos
// atribuídos a esse grupo (ver src/lib/domain/split.ts).
model IntegranteGrupo {
  id          String    @id @default(cuid())
  grupoId     String
  pessoaId    String
  peso        Int       @default(100)
  householdId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  grupo       Pessoa    @relation("IntegranteGrupo_grupoIdToPessoa", fields: [grupoId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id])
  pessoa      Pessoa    @relation("IntegranteGrupo_pessoaIdToPessoa", fields: [pessoaId], references: [id], onDelete: Cascade)

  @@unique([grupoId, pessoaId])
  @@index([householdId])
  @@index([pessoaId])
}

model AcertoContas {
  id                 String    @id @default(cuid())
  householdId        String
  dataInicio         DateTime  @db.Date
  dataFim            DateTime  @db.Date
  deId               String
  paraId             String
  valorCentavos      Int
  resolvidoEm        DateTime  @default(now())
  resolvidoPorUserId String?
  de                 Pessoa    @relation("AcertoDe", fields: [deId], references: [id])
  household          Household @relation(fields: [householdId], references: [id])
  para               Pessoa    @relation("AcertoPara", fields: [paraId], references: [id])

  @@index([householdId, resolvidoEm])
}

model Categoria {
  id            String               @id @default(cuid())
  nome          String
  householdId   String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  ativo         Boolean              @default(true)
  household     Household            @relation(fields: [householdId], references: [id])
  lancamentos   Lancamento[]
  orcamentos    OrcamentoPlanejado[]
  subcategorias Subcategoria[]

  @@unique([householdId, nome])
}

model Subcategoria {
  id                String               @id @default(cuid())
  nome              String
  categoriaId       String
  householdId       String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  ativo             Boolean              @default(true)
  orcamentoCentavos Int?
  lancamentos       Lancamento[]
  orcamentos        OrcamentoPlanejado[]
  categoria         Categoria            @relation(fields: [categoriaId], references: [id])

  @@unique([categoriaId, nome])
  @@index([householdId])
}

model Banco {
  id                 String              @id @default(cuid())
  nome               String
  householdId        String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  ativo              Boolean             @default(true)
  tipo               TipoBanco
  household          Household           @relation(fields: [householdId], references: [id])
  investimentos      Investimento[]
  lancamentos        Lancamento[]
  posicoesPatrimonio PosicaoPatrimonio[]

  @@unique([householdId, nome])
}

model Lancamento {
  id                         String        @id @default(cuid())
  data                       DateTime      @db.Date
  descricaoOrigem            String?
  descricaoPropria           String?
  valorCentavos              Int
  descontoCentavos           Int           @default(0)
  categoriaId                String?
  subcategoriaId             String?
  bancoId                    String
  pessoaDivisaoId            String
  pessoaPagouId              String
  householdId                String
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  createdByUserId            String?
  updatedByUserId            String?
  hashImportacao             String?
  pagoComResgateInvestimento Boolean       @default(false)
  investimentoResgateId      String?
  tipoGasto                  TipoGasto     @default(VARIAVEL)
  banco                      Banco         @relation(fields: [bancoId], references: [id])
  categoria                  Categoria?    @relation(fields: [categoriaId], references: [id])
  household                  Household     @relation(fields: [householdId], references: [id])
  pessoaDivisao              Pessoa        @relation("LancamentoDivisao", fields: [pessoaDivisaoId], references: [id])
  pessoaPagou                Pessoa        @relation("LancamentoPagou", fields: [pessoaPagouId], references: [id])
  subcategoria               Subcategoria? @relation(fields: [subcategoriaId], references: [id])
  investimentoResgate        Investimento? @relation(fields: [investimentoResgateId], references: [id])

  @@unique([householdId, hashImportacao])
  @@index([householdId, data])
  @@index([householdId, categoriaId])
  @@index([householdId, pessoaDivisaoId])
  @@index([householdId, pessoaPagouId])
  @@index([householdId, investimentoResgateId])
}

model Receita {
  id             String         @id @default(cuid())
  pessoaId       String
  subtipo        SubtipoReceita
  descricao      String?
  valorCentavos  Int
  mes            DateTime       @db.Date
  householdId    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  investimentoId String?        @unique
  household      Household      @relation(fields: [householdId], references: [id])
  investimento   Investimento?  @relation("ResgateInvestimento", fields: [investimentoId], references: [id])
  pessoa         Pessoa         @relation(fields: [pessoaId], references: [id])

  @@index([householdId, mes])
}

// Orçamento é sempre de uma Pessoa INDIVIDUAL (ver validarReferencias em
// src/lib/domain/orcamento.ts). O orçamento de um grupo (CASAL/FAMILIA/OUTRO)
// não é armazenado — é calculado como a soma dos orçamentos de seus
// integrantes (ver resolverPessoasEfetivas em pessoas.ts e
// buscarPlanejadoVsReal em relatorios.ts).
model OrcamentoPlanejado {
  id             String        @id @default(cuid())
  pessoaId       String
  // Com quem esse gasto planejado é dividido (Isa, Gabi, Família...) — igual
  // ao pessoaDivisaoId do Lancamento, mas opcional e independente do
  // pessoaId acima (que é sempre a Pessoa INDIVIDUAL dona do planejamento).
  divisaoId      String?
  categoriaId    String
  subcategoriaId String?
  mes            Int?
  ano            Int
  valorCentavos  Int
  tipoGasto      TipoGasto     @default(VARIAVEL)
  householdId    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  categoria      Categoria     @relation(fields: [categoriaId], references: [id])
  household      Household     @relation(fields: [householdId], references: [id])
  pessoa         Pessoa        @relation("OrcamentoDono", fields: [pessoaId], references: [id])
  divisao        Pessoa?       @relation("OrcamentoDivisao", fields: [divisaoId], references: [id])
  subcategoria   Subcategoria? @relation(fields: [subcategoriaId], references: [id])

  @@unique([householdId, pessoaId, categoriaId, subcategoriaId, mes, ano])
  @@index([householdId, ano, mes])
  @@index([householdId, divisaoId])
}

model Investimento {
  id                       String                @id @default(cuid())
  bancoId                  String
  tipo                     TipoInvestimento
  produto                  String
  valorAtualCentavos       Int
  vencimento               DateTime?             @db.Date
  liquidezDias             Int?
  observacao               String?
  pessoaId                 String
  householdId              String
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  status                   StatusInvestimento    @default(ATIVO)
  finalizadoEm             DateTime?
  valorResgatadoCentavos   Int?
  valorReinvestidoCentavos Int?
  investimentoOrigemId     String?
  banco                    Banco                 @relation(fields: [bancoId], references: [id])
  household                Household             @relation(fields: [householdId], references: [id])
  pessoa                   Pessoa                @relation(fields: [pessoaId], references: [id])
  investimentoOrigem       Investimento?         @relation("Reinvestimento", fields: [investimentoOrigemId], references: [id])
  reinvestimentos          Investimento[]        @relation("Reinvestimento")
  posicoesMensais          PosicaoInvestimento[]
  receitaResgate           Receita?              @relation("ResgateInvestimento")
  lancamentosPagos         Lancamento[]

  @@index([householdId])
  @@index([householdId, pessoaId])
}

// Posição mensal informada manualmente por investimento (produto), usada
// para acompanhar a evolução real de cada produto mês a mês — mais granular
// que PosicaoPatrimonio, que agrega apenas por banco+titular.
model PosicaoInvestimento {
  id             String       @id @default(cuid())
  investimentoId String
  // Sempre o 1º dia do mês em UTC.
  mes            DateTime     @db.Date
  valorCentavos  Int
  householdId    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  household      Household    @relation(fields: [householdId], references: [id])
  investimento   Investimento @relation(fields: [investimentoId], references: [id])

  @@unique([investimentoId, mes])
  @@index([householdId, mes])
}

model PosicaoPatrimonio {
  id            String    @id @default(cuid())
  bancoId       String
  mes           DateTime  @db.Date
  valorCentavos Int
  householdId   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  pessoaId      String?
  banco         Banco     @relation(fields: [bancoId], references: [id])
  household     Household @relation(fields: [householdId], references: [id])
  pessoa        Pessoa?   @relation(fields: [pessoaId], references: [id])

  @@unique([householdId, bancoId, pessoaId, mes])
  @@index([householdId, mes])
}

// Saldo de fechamento de um ano, informado manualmente quando não há
// lançamentos/receitas registrados nesse ano para calcular o saldo automaticamente.
model FechamentoAnual {
  id            String    @id @default(cuid())
  householdId   String
  ano           Int
  saldoCentavos Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  household     Household @relation(fields: [householdId], references: [id])

  @@unique([householdId, ano])
}

model CdiMensal {
  id         String   @id @default(cuid())
  mes        DateTime @unique @db.Date
  percentual Decimal  @db.Decimal(6, 4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum TipoPessoa {
  INDIVIDUAL
  CASAL
  FAMILIA
  OUTRO
}

enum SubtipoReceita {
  SALARIO
  VOUCHER
  INVESTIMENTO
  OUTROS
}

enum TipoInvestimento {
  RENDA_FIXA
  FUNDO
  FGTS
  OUTRO
}

enum StatusInvestimento {
  ATIVO
  FINALIZADO
}

enum TipoBanco {
  CARTAO_CREDITO
  CONTA_CORRENTE
  CORRETORA
  DINHEIRO
  OUTRO
}

enum TipoGasto {
  FIXO
  VARIAVEL
  INVESTIMENTO
}

enum PapelUsuario {
  PROPRIETARIO
  ADMIN
  EDITOR
  VISUALIZADOR
}
